+def run_transfer(
+    config: DeltxConfig,
+    train_frame: pd.DataFrame,
+    eval_frame: pd.DataFrame,
+    tune: bool,
+    feature_columns: list[str],
+) -> tuple[dict[str, Any], dict[str, Any], dict[str, Any], dict[str, Any]]:
+    """Train on one corpus and score on a disjoint one.
+
+    Replaces the stratified hold-out entirely: there is no in-distribution test
+    here, because the whole point is that the evaluation population differs from
+    the training one. Both frames arrive already class-balanced, so accuracy and
+    recall stay interpretable across the domain boundary.
+
+    Returns:
+        ``(train_result, metrics, shap_importance, extras)`` matching
+        :func:`run_headline`, so the manifest assembly path is shared.
+    """
+    x_train, y_train = to_xy(train_frame, feature_columns)
+    x_eval, y_eval = to_xy(eval_frame, feature_columns)
+
+    classifier = make_classifier(config, feature_columns)
+    train_result = classifier.train(x_train, y_train, tune_hyperparameters=tune)
+    metrics = classifier.evaluate(x_eval, y_eval)
+    # SHAP over the *evaluation* corpus: which features the model leans on when
+    # it meets unfamiliar provenance is the question this run exists to answer.
+    shap_importance = classifier.compute_shap_importance(x_eval)
+    extras = {
+        "split": SplitSizes(train=len(train_frame), test=len(eval_frame)),
+        "early_stopped_iteration": _best_iteration(classifier),
+    }
+    return train_result, metrics, shap_importance, extras
+
+
