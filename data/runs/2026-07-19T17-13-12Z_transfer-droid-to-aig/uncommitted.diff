+def validate_transfer_args(args: argparse.Namespace) -> None:
+    """Reject transfer configurations that would leak or mislead.
+
+    Raises:
+        DeltxError: If the training and evaluation corpora overlap, if no
+            training corpus was named (which would train on the eval data too),
+            or if a LOMO holdout was combined with a transfer run.
+    """
+    if not args.eval_sources:
+        return
+    if not args.sources:
+        raise DeltxError(
+            "--eval-sources needs an explicit --sources, or training would "
+            "include the evaluation corpus."
+        )
+    overlap = sorted(set(args.sources) & set(args.eval_sources))
+    if overlap:
+        raise DeltxError(
+            f"--sources and --eval-sources overlap on {overlap}; a transfer test "
+            "requires disjoint corpora."
+        )
+    if args.holdout_model:
+        # Generators are corpus-exclusive, so holding one out of a disjoint
+        # training corpus removes nothing -- the LOMO recall would be a silent
+        # no-op reported as a real measurement.
+        raise DeltxError(
+            "--holdout-model cannot be combined with --eval-sources: the two "
+            "protocols measure different things. Run them separately."
+        )
+
